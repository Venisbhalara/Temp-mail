{
  "info": {
    "name": "Temp-mail API",
    "description": "API collection for Temp-mail",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "inboxId",
      "value": "example-inbox-id",
      "type": "string"
    },
    {
      "key": "emailId",
      "value": "example-email-id",
      "type": "string"
    },
    {
      "key": "smsNumber",
      "value": "919999999999",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Temporary Email",
      "item": [
        {
          "name": "Generate Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/generate-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "generate-email"]
            }
          }
        },
        {
          "name": "Get Domains",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/domains",
              "host": ["{{baseUrl}}"],
              "path": ["api", "domains"]
            }
          }
        },
        {
          "name": "Get Inbox details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/inbox/{{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "inbox", "{{inboxId}}"]
            }
          }
        },
        {
          "name": "Delete Inbox",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/inbox/{{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "inbox", "{{inboxId}}"]
            }
          }
        },
        {
          "name": "Get Emails summary list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/emails/{{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "emails", "{{inboxId}}"]
            }
          }
        },
        {
          "name": "Get Single Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/email/{{emailId}}?inboxId={{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "email", "{{emailId}}"],
              "query": [
                {
                  "key": "inboxId",
                  "value": "{{inboxId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Single Email",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/email/{{emailId}}?inboxId={{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "email", "{{emailId}}"],
              "query": [
                {
                  "key": "inboxId",
                  "value": "{{inboxId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Poll Emails",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/poll/{{inboxId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "poll", "{{inboxId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Temporary SMS",
      "item": [
        {
          "name": "Get Available Numbers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sms/numbers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sms", "numbers"]
            }
          }
        },
        {
          "name": "Get Next Number",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sms/next/{{smsNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sms", "next", "{{smsNumber}}"]
            }
          }
        },
        {
          "name": "Get SMS Inbox",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sms/inbox/{{smsNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sms", "inbox", "{{smsNumber}}"]
            }
          }
        },
        {
          "name": "Force Refresh SMS Inbox",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sms/refresh/{{smsNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sms", "refresh", "{{smsNumber}}"]
            }
          }
        },
        {
          "name": "Force Refresh Numbers List",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sms/refresh-numbers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sms", "refresh-numbers"]
            }
          }
        }
      ]
    }
  ]
}
